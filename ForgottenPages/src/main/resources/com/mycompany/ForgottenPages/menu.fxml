<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootMenu"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.ForgottenPages.controller.MenuController"
           prefWidth="1280"
           prefHeight="720"
           minWidth="800"
           minHeight="600"
           style="-fx-background-color: black;">

    <ImageView fx:id="imgFundoMenu"
               preserveRatio="false"
               smooth="true"
               cache="true">
        <image>
            <Image url="@imagens/menu_background.png"/>
        </image>
    </ImageView>

    <Region style="-fx-background-color: rgba(0, 0, 0, 0.45);"/>

    <VBox alignment="CENTER"
          spacing="18"
          maxWidth="520"
          maxHeight="520"
          style="-fx-background-color: rgba(8, 8, 18, 0.68);
                 -fx-border-color: #C9A24A;
                 -fx-border-width: 2;
                 -fx-border-radius: 12;
                 -fx-background-radius: 12;
                 -fx-effect: dropshadow(gaussian, #000000, 24, 0.7, 0, 0);">

        <padding>
            <Insets top="42" right="70" bottom="42" left="70"/>
        </padding>

        <Label text="FORGOTTEN  PAGES"
               style="-fx-text-fill: #C9A24A;
                      -fx-font-size: 38;
                      -fx-font-weight: bold;
                      -fx-effect: dropshadow(gaussian, #FF6600, 12, 0.4, 0, 0);"/>

        <Label text="Inspirado em Library of Ruina"
               style="-fx-text-fill: #DDDDDD;
                      -fx-font-size: 15;
                      -fx-font-style: italic;"/>

        <Region prefHeight="10"/>

        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="tfNome"
                       prefWidth="260"
                       promptText="Seu nome"
                       style="-fx-background-color: rgba(20, 20, 45, 0.95);
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #AAAAAA;
                              -fx-border-color: #FFD700;
                              -fx-border-width: 1;
                              -fx-border-radius: 4;
                              -fx-background-radius: 4;
                              -fx-font-size: 14;"/>
        </HBox>

        <Button fx:id="jogar"
                text="JOGAR"
                onAction="#jogar"
                prefHeight="42"
                prefWidth="260"
                style="-fx-background-color: #8B0000;
                       -fx-text-fill: white;
                       -fx-font-size: 16;
                       -fx-font-weight: bold;
                       -fx-border-color: #FFD700;
                       -fx-border-width: 2;
                       -fx-border-radius: 6;
                       -fx-background-radius: 6;
                       -fx-effect: dropshadow(gaussian, #FF0000, 8, 0.3, 0, 0);"/>

        <Button fx:id="ranking"
                text="RANKING"
                onAction="#abrirRanking"
                prefHeight="36"
                prefWidth="260"
                style="-fx-background-color: rgba(26, 42, 26, 0.95);
                       -fx-text-fill: #88CC88;
                       -fx-font-size: 14;
                       -fx-border-color: #448844;
                       -fx-border-width: 1;
                       -fx-border-radius: 5;
                       -fx-background-radius: 5;"/>

        <Button fx:id="creditos"
                text="CRÉDITOS"
                onAction="#abrirCreditos"
                prefHeight="36"
                prefWidth="260"
                style="-fx-background-color: rgba(26, 26, 58, 0.95);
                       -fx-text-fill: #8888CC;
                       -fx-font-size: 14;
                       -fx-border-color: #444488;
                       -fx-border-width: 1;
                       -fx-border-radius: 5;
                       -fx-background-radius: 5;"/>

        <Button fx:id="encerrar"
                text="ENCERRAR"
                onAction="#fecharJogo"
                prefHeight="36"
                prefWidth="260"
                style="-fx-background-color: rgba(42, 10, 10, 0.95);
                       -fx-text-fill: #CC4444;
                       -fx-font-size: 14;
                       -fx-border-color: #882222;
                       -fx-border-width: 1;
                       -fx-border-radius: 5;
                       -fx-background-radius: 5;"/>

    </VBox>

</StackPane>