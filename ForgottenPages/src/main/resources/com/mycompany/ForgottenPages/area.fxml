<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane prefHeight="600" prefWidth="800" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ForgottenPages.controller.AreaController">

    <top>
        <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #16213e; -fx-padding: 10;">
            <Button onAction="#tfogueira" style="-fx-background-color: #1a3a1a; -fx-text-fill: #AAFFAA;                            -fx-border-color: #44AA44; -fx-border-width:1; -fx-border-radius:4; -fx-background-radius:4;" text="SKILLS " />
            <Button onAction="#tinv" style="-fx-background-color: #1a2a1a; -fx-text-fill: #88CC88;                            -fx-border-color: #448844; -fx-border-width:1; -fx-border-radius:4; -fx-background-radius:4;" text="INVENTARIO" />
            <Button onAction="#tLoja" style="-fx-background-color: #2a2a0a; -fx-text-fill: #CCCC44;                            -fx-border-color: #888800; -fx-border-width:1; -fx-border-radius:4; -fx-background-radius:4;" text="LOJA" />
        </HBox>
    </top>

    <center>
        <AnchorPane fx:id="AreaCena" style="-fx-background-color: #12122a;" />
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="18" style="-fx-background-color: #0f0f1e; -fx-padding: 12;                      -fx-border-color: #333366; -fx-border-width: 2 0 0 0;">
            <Label fx:id="lblWaveInfo" style="-fx-text-fill: #AAAAAA; -fx-font-size:13;" text="Próxima: Wave 1" />
            <Label fx:id="lblPontos" style="-fx-text-fill: #FFD700; -fx-font-size:13;" text="Pontos: 0" />
            <Label fx:id="lblMoedas" style="-fx-text-fill: #CCCC44; -fx-font-size:13;" text="Moedas: 0" />
            <Button onAction="#irParaBatalha" prefHeight="44" prefWidth="220" style="-fx-background-color: #8B0000; -fx-text-fill: white;                            -fx-font-size: 15; -fx-font-weight: bold;                            -fx-border-color: #FFD700; -fx-border-width:2;                            -fx-border-radius:6; -fx-background-radius:6;" text="ENTRAR EM BATALHA" />
        </HBox>
    </bottom>

</BorderPane>
