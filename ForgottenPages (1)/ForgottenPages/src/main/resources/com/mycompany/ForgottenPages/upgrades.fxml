<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="480" prefWidth="640" spacing="18" style="-fx-background-color: #0d0d1a;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ForgottenPages.controller.ShopController">
    <padding><Insets bottom="40" left="80" right="80" top="40" /></padding>

    <Label style="-fx-text-fill: #FFD700; -fx-font-size: 28; -fx-font-weight: bold;" text="UPGRADES" textAlignment="CENTER" />
    <Label fx:id="lblPontos" style="-fx-text-fill: #CCCCCC; -fx-font-size: 15;" text="Pontos disponíveis: 0" />
    <Label fx:id="lblFeedback" style="-fx-text-fill: #88FF88; -fx-font-size: 13; -fx-font-style: italic;" text="" />

    <VBox alignment="CENTER" spacing="12">

        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #1a2a1a; -fx-padding: 14;                      -fx-border-color: #448844; -fx-border-width: 1;                      -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label prefWidth="260" style="-fx-text-fill: white; -fx-font-size: 14;" text="+2 HP máximo" />
            <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 12;" text="Custo: 1 ponto" />
            <Button onAction="#upgradeVida" prefWidth="90" style="-fx-background-color: #224422; -fx-text-fill: #88FF88;                            -fx-border-color: #44AA44; -fx-border-radius: 4; -fx-background-radius: 4;" text="Comprar" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #2a1010; -fx-padding: 14;                      -fx-border-color: #882222; -fx-border-width: 1;                      -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label prefWidth="260" style="-fx-text-fill: white; -fx-font-size: 14;" text="+1 Dano base (skills ataque)" />
            <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 12;" text="Custo: 1 ponto" />
            <Button onAction="#upgradeDano" prefWidth="90" style="-fx-background-color: #441111; -fx-text-fill: #FF8888;                            -fx-border-color: #AA4444; -fx-border-radius: 4; -fx-background-radius: 4;" text="Comprar" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #1a1a2a; -fx-padding: 14;                      -fx-border-color: #444488; -fx-border-width: 1;                      -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label prefWidth="260" style="-fx-text-fill: white; -fx-font-size: 14;" text="+1 Poder de moeda a cada 10 níveis" />
            <Label style="-fx-text-fill: #AAAAAA; -fx-font-size: 12;" text="Custo: 1 ponto" />
            <Button onAction="#upgradeClash" prefWidth="90" style="-fx-background-color: #111133; -fx-text-fill: #8888FF;                            -fx-border-color: #4444AA; -fx-border-radius: 4; -fx-background-radius: 4;" text="Comprar" />
        </HBox>

    </VBox>

    <Button onAction="#voltar" prefHeight="36" prefWidth="160" style="-fx-background-color: #2a0a0a; -fx-text-fill: #CC4444; -fx-font-size: 13;                    -fx-border-color: #882222; -fx-border-width: 1;                    -fx-border-radius: 5; -fx-background-radius: 5;" text="VOLTAR" />
</VBox>
