<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.ForgottenPages.controller.BattleController"
           prefWidth="980"
           prefHeight="620"
           style="-fx-background-color: black;">

    <ImageView fitWidth="1920"
               fitHeight="1080"
               preserveRatio="false"
               smooth="true"
               cache="true">
        <image>
            <Image url="@livraria.png"/>
        </image>
    </ImageView>

    <Region style="-fx-background-color: rgba(0, 0, 0, 0.30);"/>

    <BorderPane style="-fx-background-color: transparent;" prefWidth="980" prefHeight="620">

        <top>
            <HBox alignment="CENTER" spacing="20" style="-fx-background-color: rgba(22, 33, 62, 0.88); -fx-padding: 8;">
                <Label fx:id="lblWave" text="Wave 1"
                       style="-fx-text-fill: #FFD700; -fx-font-size: 18; -fx-font-weight: bold;"/>

                <Label fx:id="lblTurno" text="Turno: 1"
                       style="-fx-text-fill: #AAAAAA; -fx-font-size: 14;"/>

                <Label fx:id="lblPontos" text="Pontos: 0 | Moedas: 0"
                       style="-fx-text-fill: #CCCC44; -fx-font-size: 13;"/>
            </HBox>
        </top>

        <center>
            <HBox spacing="14" alignment="TOP_CENTER">
                <padding>
                    <Insets top="16" right="16" bottom="0" left="16"/>
                </padding>

                <VBox spacing="16" alignment="TOP_CENTER" HBox.hgrow="ALWAYS">

                    <HBox spacing="40" alignment="CENTER">

                        <VBox spacing="6" alignment="CENTER"
                              style="-fx-background-color: rgba(42, 16, 16, 0.88); -fx-border-color: #CC2222; -fx-border-width:2;
                                     -fx-border-radius:8; -fx-background-radius:8; -fx-padding: 12;"
                              prefWidth="300">

                            <Label text="INIMIGO"
                                   style="-fx-text-fill: #CC4444; -fx-font-size:11; -fx-font-weight:bold;"/>

                            <ImageView fx:id="imgEnemy"
                                       fitWidth="210"
                                       fitHeight="210"
                                       preserveRatio="true"
                                       smooth="true"
                                       cache="true">
                                <image>
                                    <Image url="@goblin.png"/>
                                </image>
                            </ImageView>

                            <Label fx:id="lblEnemyName" text="Goblin"
                                   style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight:bold;"/>

                            <ProgressBar fx:id="pbEnemyHp" prefWidth="250" prefHeight="14" progress="1.0"
                                         style="-fx-accent: #CC2222;"/>

                            <Label fx:id="lblEnemyHp" text="100/100"
                                   style="-fx-text-fill: #CCCCCC; -fx-font-size:12;"/>
                        </VBox>

                        <Label text="VS" style="-fx-font-size:28; -fx-text-fill: #FFD700; -fx-font-weight:bold;"/>

                        <VBox spacing="6" alignment="CENTER"
                              style="-fx-background-color: rgba(13, 31, 60, 0.88); -fx-border-color: #4488CC; -fx-border-width:2;
                                     -fx-border-radius:8; -fx-background-radius:8; -fx-padding: 12;"
                              prefWidth="300">

                            <Label text="PLAYER"
                                   style="-fx-text-fill: #4488CC; -fx-font-size:11; -fx-font-weight:bold;"/>

                            <ImageView fx:id="imgPlayer"
                                       fitWidth="210"
                                       fitHeight="210"
                                       preserveRatio="true"
                                       smooth="true"
                                       cache="true">
                                <image>
                                    <Image url="@cavaleiro.png"/>
                                </image>
                            </ImageView>

                            <Label fx:id="lblPlayerName" text="Player"
                                   style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight:bold;"/>

                            <ProgressBar fx:id="pbPlayerHp" prefWidth="250" prefHeight="14" progress="1.0"
                                         style="-fx-accent: #44BB44;"/>

                            <Label fx:id="lblPlayerHp" text="100/100"
                                   style="-fx-text-fill: #CCCCCC; -fx-font-size:12;"/>
                        </VBox>

                    </HBox>

                    <Label fx:id="lblStatus" text="Escolha sua skill."
                           style="-fx-text-fill: #FFD700; -fx-font-size:13; -fx-font-style:italic;"/>

                    <TextArea fx:id="taLog" editable="false" prefHeight="70" minHeight="60" maxHeight="85"
                              style="-fx-control-inner-background: #0d0d1a; -fx-text-fill: #DDDDDD;
                                     -fx-font-family: monospace; -fx-font-size: 12;
                                     -fx-border-color: #333366; -fx-border-width:1;"/>

                </VBox>

                <VBox spacing="8" prefWidth="265"
                      style="-fx-background-color: rgba(15, 15, 35, 0.90); -fx-border-color: #333366; -fx-border-width: 1;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;">

                    <Label text="BATALHA"
                           style="-fx-text-fill: #FFD700; -fx-font-size: 15; -fx-font-weight: bold;"/>

                    <Label text="Inventário e decks acessíveis durante o combate"
                           wrapText="true"
                           style="-fx-text-fill: #AAAAAA; -fx-font-size: 11;"/>

                    <TabPane tabClosingPolicy="UNAVAILABLE" prefHeight="360" VBox.vgrow="ALWAYS">

                        <Tab text="Inventário">
                            <content>
                                <VBox spacing="8" style="-fx-background-color: #12122a; -fx-padding: 8;">

                                    <ListView fx:id="listItensBatalha" prefHeight="250" VBox.vgrow="ALWAYS"
                                              style="-fx-background-color: #12122a; -fx-control-inner-background: #12122a;
                                                     -fx-text-fill: white; -fx-border-color: #333366; -fx-border-width: 1;"/>

                                    <Button text="Usar poção de vida" onAction="#usarPocaoNaBatalha"
                                            prefWidth="220" prefHeight="32"
                                            style="-fx-background-color: #1a3a1a; -fx-text-fill: #AAFFAA;
                                                   -fx-border-color: #44AA44; -fx-border-width: 1;
                                                   -fx-border-radius: 4; -fx-background-radius: 4;"/>
                                </VBox>
                            </content>
                        </Tab>

                        <Tab text="Decks">
                            <content>
                                <VBox spacing="8" style="-fx-background-color: #12122a; -fx-padding: 8;">

                                    <ListView fx:id="listDeckBatalha" prefHeight="300" VBox.vgrow="ALWAYS"
                                              style="-fx-background-color: #12122a; -fx-control-inner-background: #12122a;
                                                     -fx-text-fill: white; -fx-border-color: #333366; -fx-border-width: 1;"/>
                                </VBox>
                            </content>
                        </Tab>

                    </TabPane>
                </VBox>

            </HBox>
        </center>

        <bottom>
            <VBox style="-fx-background-color: rgba(15, 15, 35, 0.92); -fx-border-color: #333366; -fx-border-width: 2 0 0 0;"
                  alignment="CENTER" spacing="6">

                <padding>
                    <Insets top="10" bottom="12" left="10" right="10"/>
                </padding>

                <Label text="SKILLS DO DECK"
                       style="-fx-text-fill: #888888; -fx-font-size:11; -fx-font-weight:bold;"/>

                <HBox fx:id="hboxSkills" alignment="CENTER" spacing="10"/>
            </VBox>
        </bottom>

    </BorderPane>
</StackPane>
