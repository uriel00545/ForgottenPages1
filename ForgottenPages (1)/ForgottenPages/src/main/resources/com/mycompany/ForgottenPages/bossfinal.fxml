<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.ForgottenPages.controller.BossFinalController"
           prefWidth="800"
           prefHeight="600"
           style="-fx-background-color: black;">

    <ImageView fitWidth="1920"
               fitHeight="1080"
               preserveRatio="false"
               smooth="true"
               cache="true">
        <image>
            <Image url="@livraria.png"/>
        </image>
    </ImageView>

    <Region style="-fx-background-color: rgba(0, 0, 0, 0.42);"/>

    <BorderPane style="-fx-background-color: transparent;" prefWidth="800" prefHeight="600">
        <top>
            <HBox alignment="CENTER" spacing="30"
                  style="-fx-background-color: rgba(26, 0, 32, 0.90); -fx-padding: 10;
                         -fx-border-color: #AA00AA; -fx-border-width: 0 0 2 0;">
                <Label text="DESAFIO FINAL"
                       style="-fx-text-fill: #FF44FF; -fx-font-size: 20; -fx-font-weight: bold;
                              -fx-effect: dropshadow(gaussian, #FF00FF, 10, 0.5, 0, 0);"/>
                <Label fx:id="lblFase" text="Fase 1"
                       style="-fx-text-fill: #FF8800; -fx-font-size: 15; -fx-font-weight: bold;"/>
            </HBox>
        </top>

        <center>
            <VBox spacing="14" alignment="TOP_CENTER">
                <padding>
                    <Insets top="16" right="20" bottom="0" left="20"/>
                </padding>

                <HBox spacing="40" alignment="CENTER">
                    <VBox spacing="6" alignment="CENTER" prefWidth="270"
                          style="-fx-background-color: rgba(32, 0, 16, 0.90); -fx-border-color: #AA00AA;
                                 -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                        <Label text="BOSS FINAL" style="-fx-text-fill: #FF44FF; -fx-font-size: 11; -fx-font-weight: bold;"/>
                        <ImageView fx:id="imgBoss"
                                   fitWidth="150"
                                   fitHeight="150"
                                   preserveRatio="true"
                                   smooth="true"
                                   cache="true">
                            <image>
                                <Image url="@reiesqueleto.png"/>
                            </image>
                        </ImageView>
                        <Label fx:id="lblBossName" text="Rei Esqueleto"
                               style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <ProgressBar fx:id="pbBossHp" prefWidth="220" prefHeight="14" progress="1.0"
                                     style="-fx-accent: #CC2222;"/>
                        <Label fx:id="lblBossHp" text="500/500" style="-fx-text-fill: #CCCCCC; -fx-font-size: 12;"/>
                    </VBox>

                    <Label text="VS" style="-fx-font-size: 28; -fx-text-fill: #FF44FF; -fx-font-weight: bold;"/>

                    <VBox spacing="6" alignment="CENTER" prefWidth="250"
                          style="-fx-background-color: rgba(13, 31, 60, 0.90); -fx-border-color: #4488CC;
                                 -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                        <Label text="PLAYER" style="-fx-text-fill: #4488CC; -fx-font-size: 11; -fx-font-weight: bold;"/>
                        <ImageView fx:id="imgPlayer"
                                   fitWidth="150"
                                   fitHeight="150"
                                   preserveRatio="true"
                                   smooth="true"
                                   cache="true">
                            <image>
                                <Image url="@cavaleiro.png"/>
                            </image>
                        </ImageView>
                        <ProgressBar fx:id="pbPlayerHp" prefWidth="200" prefHeight="14" progress="1.0"
                                     style="-fx-accent: #44BB44;"/>
                        <Label fx:id="lblPlayerHp" text="100/100" style="-fx-text-fill: #CCCCCC; -fx-font-size: 12;"/>
                    </VBox>
                </HBox>

                <Label fx:id="lblStatus" text=""
                       style="-fx-text-fill: #FF8800; -fx-font-size: 13; -fx-font-style: italic;"/>
                <TextArea fx:id="taLog" editable="false" prefHeight="135"
                          style="-fx-control-inner-background: #0a0005; -fx-text-fill: #FF88FF;
                                 -fx-font-family: monospace; -fx-font-size: 12;
                                 -fx-border-color: #440044; -fx-border-width: 1;"/>
            </VBox>
        </center>

        <bottom>
            <VBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: rgba(16, 0, 21, 0.92); -fx-border-color: #440044;
                         -fx-border-width: 2 0 0 0; -fx-padding: 10;">
                <Label text="SKILLS" style="-fx-text-fill: #888888; -fx-font-size: 11; -fx-font-weight: bold;"/>
                <HBox fx:id="hboxSkills" alignment="CENTER" spacing="10"/>
            </VBox>
        </bottom>
    </BorderPane>
</StackPane>
